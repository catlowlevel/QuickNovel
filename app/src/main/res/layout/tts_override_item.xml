<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/override_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:buttonTint="?attr/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <EditText
                android:id="@+id/override_original"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/original_text"
                android:paddingVertical="2dp"
                android:textColor="?attr/textColor"
                android:textColorHint="@color/white_attr_20"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/override_replacement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/replacement_text"
                android:paddingVertical="2dp"
                android:textColor="?attr/textColor"
                android:textColorHint="@color/white_attr_20"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/override_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorOngoing"
                android:textSize="11sp"
                android:paddingVertical="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/override_move"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_baseline_public_24"
            app:tint="?attr/white" />

        <ImageButton
            android:id="@+id/override_delete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_baseline_delete_outline_24"
            app:tint="?attr/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:orientation="horizontal">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/override_regex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/use_regex"
            android:textSize="11sp"
            app:buttonTint="?attr/white" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/override_case_sensitive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="@string/case_sensitive"
            android:textSize="11sp"
            app:buttonTint="?attr/white" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="4dp"
        android:background="@color/white_attr_20" />
</LinearLayout>
